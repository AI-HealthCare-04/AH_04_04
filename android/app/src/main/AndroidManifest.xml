<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- 걷기 감지는 가속도계 기반. 런타임 권한은 불필요.
         센서가 없는 기기에서도 설치 가능하도록 required=false -->
    <uses-feature android:name="android.hardware.sensor.accelerometer" android:required="false" />

    <application
        android:name=".AigoApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MyApplication">

        <!-- Android 16(targetSdk 36)부터 sw600dp 이상 대형 화면에서는 screenOrientation=portrait가
             기본 무시된다. 이 opt-out으로 태블릿·폴더블에서도 세로 고정을 실제 보장해 회전 시 측정값·타이머
             리셋(#122)을 막는다. ⚠️ opt-out은 targetSdk 37부터 효력이 없어지므로, 그 전에 #90의 생명주기
             복원(ViewModel/rememberSaveable 세션 복원)으로 대체하는 것이 최종 해법이다. -->
        <property
            android:name="android.window.PROPERTY_COMPAT_ALLOW_RESTRICTED_RESIZABILITY"
            android:value="true" />

        <activity
            android:name="com.kakao.sdk.auth.AuthCodeHandlerActivity"
            android:exported="true"
            tools:ignore="Instantiatable">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="kakao${KAKAO_NATIVE_APP_KEY}" android:host="oauth" />
            </intent-filter>
        </activity>
        <!-- 세로 고정: 시니어 대상 세로 전용 UI(가로 레이아웃 없음). 회전 시 Activity 재생성으로
             걸음수·10분 타이머가 리셋되는 문제 방지(#122). 대형 화면은 위 RESTRICTED_RESIZABILITY
             opt-out으로 함께 보장. 대형/폴더블 권장 경고는 의도적 결정이라 무시. -->
        <activity
            android:name=".pet.WalkingChallengeActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.MyApplication"
            tools:ignore="LockedOrientationActivity,DiscouragedApi" />

        <!-- 세로 고정: 전 화면이 시니어 대상 세로 전용 UI(가로 레이아웃 없음). 자동회전 시
             MainActivity 재생성으로 탭·측정 상태(센서 걸음수 등)가 전부 리셋되는 문제 방지(#122).
             대형 화면은 위 RESTRICTED_RESIZABILITY opt-out으로 함께 보장.
             대형/폴더블 권장 경고는 v1의 의도적 결정이라 무시. -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.MyApplication"
            android:windowSoftInputMode="adjustResize"
            tools:ignore="LockedOrientationActivity,DiscouragedApi">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
