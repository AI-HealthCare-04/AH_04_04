<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- STT 음성 보조입력(SpeechRecognizer). 런타임 권한 요청 필요. -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Android 11+ 에서 음성 인식 서비스 패키지 가시성 확보 -->
    <queries>
        <intent>
            <action android:name="android.speech.RecognitionService" />
        </intent>
    </queries>

    <!-- 걷기·흔들기 모두 가속도계 기반. 런타임 권한은 불필요.
         센서가 없는 기기에서도 설치 가능하도록 required=false -->
    <uses-feature android:name="android.hardware.sensor.accelerometer" android:required="false" />

    <application
        android:name=".AigoApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MyApplication">
        <activity
            android:name="com.kakao.sdk.auth.AuthCodeHandlerActivity"
            android:exported="true"
            tools:ignore="Instantiatable">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="kakao${KAKAO_NATIVE_APP_KEY}" android:host="oauth" />
            </intent-filter>
        </activity>
        <!-- 세로 고정: 시니어 대상 세로 전용 UI(가로 레이아웃 없음). 회전 시 Activity 재생성으로
             걸음수·10분 타이머가 리셋되는 문제 방지(#122). 대형/폴더블 권장 경고는 의도적 결정이라 무시. -->
        <activity
            android:name=".pet.WalkingChallengeActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.MyApplication"
            tools:ignore="LockedOrientationActivity,DiscouragedApi" />

        <!-- 세로 고정: 전 화면이 시니어 대상 세로 전용 UI(가로 레이아웃 없음). 자동회전 시
             MainActivity 재생성으로 탭·측정 상태(센서 걸음수 등)가 전부 리셋되는 문제 방지(#122).
             대형/폴더블 권장 경고는 v1의 의도적 결정이라 무시. -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.MyApplication"
            android:windowSoftInputMode="adjustResize"
            tools:ignore="LockedOrientationActivity,DiscouragedApi">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
