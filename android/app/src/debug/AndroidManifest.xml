<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <application android:networkSecurityConfig="@xml/network_security_config">

        <!-- #131 파형 수집(디버그 전용): 설정 화면의 BuildConfig.DEBUG 게이트에서만 실행. exported=false. -->
        <activity
            android:name="com.aihealthcare.ah0404.sensor.WaveformCaptureActivity"
            android:exported="false"
            android:label="파형 수집(디버그)" />

        <!-- 수집 CSV 공유용 FileProvider. debug 소스셋에만 있어 릴리스에는 포함되지 않는다. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/waveform_file_paths" />
        </provider>
    </application>
</manifest>
